TELEGRAM_BOT_TOKEN=your_bot_token_here
DEBUG=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=fitbot
DB_PASSWORD=fitbot_password
DB_NAME=fitness_bot
DB_SSLMODE=disable

# Admin API
ADMIN_PORT=8080
ADMIN_API_KEY=your_admin_api_key_here

# WebApp (Mini App)
WEBAPP_PORT=8081
WEBAPP_URL=https://your-domain.com

# Robokassa (leave empty to use DummyProvider for testing)
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_IS_TEST=true

# Cloudflare R2 object storage. Empty R2_ACCESS_KEY_ID disables /app/api/media/*.
# Generate Access Key ID + Secret in: Dashboard -> R2 -> Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PRIVATE=fitness-bot
R2_BUCKET_PUBLIC=fitness-bot-public
R2_PUBLIC_URL=
# Hard cap on total confirmed media bytes. Default 9.5 GB leaves headroom under
# R2's 10 GB free tier so an over-quota upload never tips us into paid usage.
MEDIA_QUOTA_BYTES=9500000000
